[0m13:28:57.611540 [debug] [Thread-4 (]: On model.tpch_dbt.mart_revenue_summary: /* {"app": "dbt", "dbt_version": "1.10.1", "profile_name": "tpch_project_profile", "target_name": "dev", "node_id": "model.tpch_dbt.mart_revenue_summary"} */

  
    

    create table "iceberg"."tpch_mart_mart"."mart_revenue_summary"
      
      
    as (
      with orders as (
    select * from "iceberg"."tpch_mart_staging"."stg_orders"
),

lineitem as (
    select * from "iceberg"."tpch_mart_staging"."stg_lineitem"
)

select 
    o.order_priority,
    lineitem.line_status,
    count(distinct o.order_id) as total_orders,

    -- jinja macro to calculate discounted price
    sum(
    lineitem.extended_price * (1 - lineitem.discount)
) as total_net_revenue

from lineitem
join orders o on lineitem.order_id = o.order_id
group by 1, 2
order by total_net_revenue desc
    )
